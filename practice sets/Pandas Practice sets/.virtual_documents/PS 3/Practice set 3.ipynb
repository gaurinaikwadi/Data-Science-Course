# 16.

import pandas as pd

# Create left_df
left_df = pd.DataFrame({
    "user_id": [1, 2, 3, 4],
    "name": ["Om", "Raj", "Sam", "Amit"]
})

# Create right_df
right_df = pd.DataFrame({
    "id": [1, 2, 4],
    "score": [85, 90, 95]
})

# Left join
result = pd.merge(
    left_df,
    right_df,
    left_on="user_id",
    right_on="id",
    how="left"
)

print(result)



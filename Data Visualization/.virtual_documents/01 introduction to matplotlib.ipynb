import matplotlib.pyplot as plt
years = [2011, 2012, 2013, 2014, 2015, 2016, 2017, 2018, 2019, 2020]

kohli = [1200, 1350, 1450, 1500, 1600, 1750, 1800, 1900, 1850, 1700]

rohit = [950, 1050, 1150, 1250, 1350, 1450, 1550, 1650, 1750, 1600]

sehwag = [1100, 980, 850, 700, 650, 600, 550, 500, 450, 400]

plt.plot(years, kohli,  color='orange', linestyle='--' ,linewidth=3, label="Virat Kohli")
plt.plot(years, rohit,  color='green', linestyle='-.' ,linewidth=3,label="Rohit Sharma")
plt.plot(years, sehwag, color='blue', linestyle="-", linewidth=3,label="Virender Sehwag")

plt.xlabel("Year")
plt.ylabel("Runs Scored")
plt.title("Performance Comparison")

plt.style.use('custom')    
# plt.grid(True)

plt.legend()



